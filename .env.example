# =============================================================================
# siyuan-wiki — Environment Configuration
# Copy this to .env and set your SiYuan notebook before using skills.
# =============================================================================
#
# This project is a fork of obsidian-wiki, with the storage backend swapped
# from filesystem-based Obsidian vault to SiYuan note (via siyuan-sisyphus
# CLI). All path-shaped concepts (vault path, sources dir, categories) become
# SiYuan-native concepts (notebook name, document hpaths, document subtrees).

# --- Required ---

# SiYuan notebook ID — immutable id like 20241205084226-rl6jd3a.
# Used for `--notebook` arguments, `query_sql ... WHERE box='<id>'`,
# document lookup, document create, notebook get-permissions.
# Survives notebook rename. Two notebooks can share a name; only the
# id is guaranteed unique.
# `wiki-setup` discovers the id via `siyuan-sisyphus notebook list --json`
# after asking you for the name; you should not need to look this up by hand.
SIYUAN_NOTEBOOK_ID=

# SiYuan notebook NAME (e.g. 模型代理).
# Used for `fs *` workspace paths (which require the name as the first
# segment, e.g. `/模型代理/index`) and for human-facing log lines and
# error messages. The CLI does not accept the id in `fs *` paths.
# If you rename the notebook in SiYuan, update this value to keep
# `fs *` calls working — `wiki-setup --check` warns about staleness.
SIYUAN_NOTEBOOK_NAME=

# --- Optional ---

# Comma-separated source directories (filesystem paths) to ingest documents
# from. Sources are still read off the local filesystem; only the wiki itself
# lives in SiYuan. Leave empty to skip document ingestion.
SIYUAN_SOURCES_DIR=

# Wiki categories (top-level document subtrees created in the notebook).
SIYUAN_CATEGORIES=concepts,entities,skills,references,synthesis,journal

# Max pages to create/update per ingest operation.
SIYUAN_MAX_PAGES_PER_INGEST=15

# Internal link format for generated/updated pages — INFORMATIONAL ONLY.
# All body links between wiki pages are emitted as SiYuan native block
# references ((<doc-id> "display text")), regardless of this setting.
# SiYuan does NOT parse [[wikilink]] markdown or [text](path) markdown links
# as graph edges — see .skills/llm-wiki/SKILL.md §13 note 7 and §15.
# This variable is read for back-compat but does not change behaviour.
SIYUAN_LINK_FORMAT=blockref

# --- SiYuan CLI / API ---
#
# siyuan-sisyphus reads its profile and SiYuan API endpoint from the same
# config file (~/.config/siyuan-sisyphus/config.toml or env vars). The two
# variables below are forwarded to siyuan-sisyphus when the skill needs to
# override the profile (multi-notebook workflows, CI, etc.).

# Override siyuan-sisyphus profile (matches a [profiles.<name>] block in
# its config). Empty = use default profile.
SIYUAN_PROFILE=

# Run startup preflight (siyuan-sisyphus --version + notebook list) before
# every write-class skill. Set false in non-interactive automation only.
SIYUAN_PRECHECK=true

# --- Source history paths (filesystem-backed, read by claude-history-ingest) ---

# Claude conversation history path (auto-discovered from ~/.claude if empty)
CLAUDE_HISTORY_PATH=

# Lint schedule: daily | weekly | manual
LINT_SCHEDULE=weekly

# --- Raw Staging Subtree (optional) ---
#
# A subtree document path (relative to notebook root) for unprocessed draft
# pages. Drop rough notes via `siyuan-sisyphus fs write --path "/<notebook>
# /_raw/<slug>" --markdown ...` and wiki-ingest will promote them to proper
# wiki pages on its next run, then delete the originals.
SIYUAN_RAW_DIR=_raw
